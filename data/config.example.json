{
  "log_level": "INFO",
  "language": "zh-CN",
  "send_report_to_source": true,

  "channels": {
    "https://t.me/example_channel1": {
      "summary": {
        "schedule": {
          "frequency": "weekly",
          "days": ["mon"],
          "hour": 9,
          "minute": 0
        }
      },
      "poll": {
        "enabled": true,
        "regen_threshold": 5,
        "enable_vote_regen_request": true,
        "send_to_channel": true
      },
      "comment_chat": {
        "enabled": true,
        "wake_keyword": "小樱",
        "debounce_seconds": 3,
        "session_timeout": 30,
        "max_context_messages": 50
      },
      "comment_welcome": {
        "enabled": true,
        "welcome_message": "comment_welcome.message",
        "button_text": "comment_welcome.button",
        "button_action": "request_summary"
      }
    },

    "https://t.me/example_channel2": {
      "summary": {
        "schedule": {
          "frequency": "daily",
          "hour": 23,
          "minute": 0
        }
      },
      "poll": {
        "enabled": true,
        "regen_threshold": 5,
        "enable_vote_regen_request": true,
        "send_to_channel": false
      },
      "comment_chat": {
        "enabled": true,
        "wake_keyword": "小樱",
        "debounce_seconds": 3,
        "session_timeout": 30,
        "max_context_messages": 50
      },
      "comment_welcome": {
        "enabled": false
      }
    }
  },

  "forwarding": {
    "enabled": false,
    "show_default_footer": true,
    "rules": [
      {
        "source_channel": "https://t.me/example_channel1",
        "target_channel": "https://t.me/my_channel",
        "keywords": ["关键词1", "关键词2"],
        "blacklist": ["广告", "垃圾"],
        "patterns": [],
        "blacklist_patterns": [],
        "copy_mode": false,
        "forward_original_only": false,
        "custom_footer": "📢 来源: {source_title}\\n🔗 {source_link}"
      }
    ]
  }
}

